# Copy to backend/.env for local development.
# Keep real environment files untracked.

ENVIRONMENT=development
MODEL_SIZE=base
DEVICE=cpu
COMPUTE_TYPE=int8
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
DEFAULT_TRANSCRIPTION_DOMAIN=general
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_MODEL=gemma-4-e2b-it-mlx
LM_STUDIO_TIMEOUT_SECONDS=30
TTS_PROVIDER=supertonic
SUPERTONIC_VOICE=M1
SUPERTONIC_LANG=en
TTS_OUTPUT_DIR=

TRANSCRIPTION_PROFILE=balanced_realtime
MIN_CHUNK_DURATION_SECONDS=0.6
MAX_CHUNK_DURATION_SECONDS=6.0
SILENCE_TIMEOUT_SECONDS=0.7

ACCENT_SUPPORT_ENABLED=true
TRANSCRIPTION_LANGUAGE=en
BEAM_SIZE=2
MIN_TRANSCRIPTION_CONFIDENCE=0.10
HALLUCINATION_MAX_NO_SPEECH_PROB=0.65
